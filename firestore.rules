rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admins can read and write anything
    match /{document=**} {
      allow read, write: if get(/databases/$(database)/documents/admins/$(request.auth.uid)).exists;
    }

    // Players can read games and their own data
    match /games/{gameId} {
      allow read: if request.auth != null;
    }

    match /players/{playerId} {
      allow read, write: if request.auth.uid == playerId;

      match /transactions/{transactionId} {
        allow read, write: if request.auth.uid == playerId;
      }
    }

    match /games/{gameId}/playerData/{playerId} {
        allow read, write: if request.auth.uid == playerId;
    }
  }
}
